# Public env vars for Next.js client + server rendering

# Supabase Proxy URL (includes project_id)
NEXT_PUBLIC_SUPABASE_URL=https://cloud.noqte.ai/functions/v1/proxy/YOUR_PROJECT_ID

# Supabase Anon Key (public key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Base URL for your backend proxy (without /functions/v1/...)
NEXT_PUBLIC_API_URL=https://cloud.noqte.ai

# Project identifier used by edge-function routes
NEXT_PUBLIC_PROJECT_ID=YOUR_PROJECT_ID

# Public site URL for metadata/sitemap canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:8080
