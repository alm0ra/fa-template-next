# Public site URL for metadata/sitemap canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:8080

# Locale: "fa" (default) or "en"
NEXT_PUBLIC_LOCALE=fa

# Platform metadata — injected by the builder/control-plane at runtime
PROJECT_ID=project-demo
VERSION=2
RUNTIME_LANE=shared

# libSQL connection — injected by the platform at runtime in production.
# For local human dev (running `npm run dev` outside the agent), the
# @libsql/client falls back to a local SQLite file when DATABASE_URL is
# unset. See drizzle.config.ts for the same fallback.
#
#   Production:  DATABASE_URL=libsql://proj-xxx.sqld.example
#   Local dev:   DATABASE_URL=file:./dev.db
#
DATABASE_URL=file:./dev.db
DATABASE_AUTH_TOKEN=
